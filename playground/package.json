    "svelte": "^5.46.1",
    "typescript": "^5.8.2",
    "vite": "^8.0.0-beta.5"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "monaco-editor": "^0.55.1"
