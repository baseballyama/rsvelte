#!/usr/bin/env node
// Launcher for the @rsvelte/lint CLI.
//
// This resolves the right `@rsvelte/lint-<triple>` binary and execs it,
// forwarding argv/stdio and propagating the exit code/signal — one Node cold
// start per invocation.
//
// There used to be a `postinstall` step that swapped this file for the
// native binary in place (an esbuild-style trick to skip the Node start), but
// package managers don't agree on how `bin` entries reach the native binary:
// npm/yarn classic symlink `node_modules/.bin/<name>` straight at this file,
// so replacing its bytes made the symlink point at the native binary and it
// ran directly. pnpm instead generates a shim script, and it decides the
// shim's interpreter by sniffing THIS file's shebang at link time — before
// postinstall has necessarily run. If the sniff sees `#!/usr/bin/env node`
// (this file, pre-swap) it bakes `exec node ".../bin/rsvelte-lint" "$@"` into
// the shim permanently; postinstall's later swap to a native binary just
// makes that baked-in Node try to parse Mach-O/ELF bytes as JS
// (`SyntaxError: Invalid or unexpected token`, #1723). Never mutating this
// file removes the race: every package manager's shim/symlink correctly runs
// it via Node, always.
//
// Unlike @rsvelte/fmt this launcher has nothing extra to wire up: the linter is
// self-contained (no oxfmt delegation, no runtime sidecar). It just resolves
// the platform binary and forwards argv/stdio.

const { spawnSync } = require('node:child_process');
const {
	platformPackage,
	resolvePlatformBinary,
	ensureExecutable,
} = require('../lib/resolve.cjs');

const binPath = resolvePlatformBinary();
if (!binPath) {
	const { triple, pkgName } = platformPackage();
	if (!triple) {
		console.error(
			`[@rsvelte/lint] Unsupported platform: ${process.platform}-${process.arch}.\n` +
				`Open an issue at https://github.com/baseballyama/rsvelte/issues if you'd like this platform supported.`,
		);
	} else {
		console.error(
			`[@rsvelte/lint] Couldn't find the platform binary "${pkgName}".\n` +
				`This usually means npm/pnpm skipped the optional dependency for your platform.\n` +
				`Try reinstalling: npm install --include=optional ${pkgName}`,
		);
	}
	process.exit(1);
}

// `pnpm pack` normalises file modes to 0644, dropping the execute bit. Re-apply
// +x best-effort right before spawn so the binary can actually run.
ensureExecutable(binPath);

const result = spawnSync(binPath, process.argv.slice(2), {
	stdio: 'inherit',
	windowsHide: true,
});

if (result.error) {
	console.error(`[@rsvelte/lint] Failed to exec ${binPath}: ${result.error.message}`);
	process.exit(1);
}

// If the native binary was killed by a signal (e.g. SIGABRT from a Rust
// panic), `result.status` is null and `result.signal` holds the signal name.
// Returning `status ?? 0` would mask the crash as a clean exit 0; propagate
// signal terminations as the conventional 128 + signal-number exit code.
if (result.signal) {
	const signum = require('node:os').constants.signals[result.signal];
	console.error(`[@rsvelte/lint] ${binPath} was terminated by ${result.signal}.`);
	process.exit(typeof signum === 'number' ? 128 + signum : 1);
}
process.exit(result.status ?? 0);
