{
  "name": "@rsvelte/language-server",
  "version": "0.2.1",
  "description": "Language Server for rsvelte — formatting (native rsvelte-fmt) and linting (bundled rsvelte_lint wasm)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/rsvelte.git",
    "directory": "apps/npm/language-server"
  },
  "homepage": "https://github.com/baseballyama/rsvelte/tree/main/apps/npm/language-server#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/rsvelte/issues"
  },
  "keywords": [
    "svelte",
    "language-server",
    "lsp",
    "formatter",
    "linter",
    "rust"
  ],
  "type": "module",
  "bin": {
    "rsvelte-language-server": "dist/server.mjs"
  },
  "files": [
    "dist/server.mjs",
    "dist/vendor/rsvelte_lint.cjs",
    "dist/vendor/rsvelte_lint_bg.wasm"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"test/*.test.mjs\"",
    "prepublishOnly": "node -e \"for (const f of ['dist/server.mjs','dist/vendor/rsvelte_lint.cjs','dist/vendor/rsvelte_lint_bg.wasm']) if (!require('fs').existsSync(f)) { console.error('missing '+f+' — run build:language-server first'); process.exit(1) }\""
  },
  "dependencies": {
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
