{
  "name": "shadcn-svelte",
  "repo": "https://github.com/huntabyte/shadcn-svelte",
  "license": "MIT",
  "branch": "main",
  "type": "app",
  "swap": {
    "strategy": "vps-shim"
  },
  "commands": {
    "install": "pnpm install --no-frozen-lockfile",
    "build": "pnpm -F docs build"
  },
  "timeoutMinutes": 30,
  "tags": ["ui-library", "sveltekit"],
  "allowList": {
    "expectedBaselineFailures": []
  }
}
