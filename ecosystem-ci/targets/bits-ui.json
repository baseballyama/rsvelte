{
  "name": "bits-ui",
  "repo": "https://github.com/huntabyte/bits-ui",
  "license": "MIT",
  "branch": "main",
  "type": "tool",
  "swap": {
    "strategy": "vps-shim"
  },
  "commands": {
    "install": "pnpm install --no-frozen-lockfile",
    "build": "pnpm -F bits-ui build",
    "test": "pnpm -F bits-ui test:unit -- --run"
  },
  "timeoutMinutes": 30,
  "tags": ["ui-library", "headless"],
  "allowList": {
    "expectedBaselineFailures": []
  }
}
