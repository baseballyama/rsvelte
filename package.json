{
  "name": "svelte-compiler-rust-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build --target web --release -- --features wasm --no-default-features",
    "build:wasm:clean": "cargo clean && pnpm run build:wasm",
    "clean:cache": "rm -rf docs/node_modules/.vite",
    "dev": "pnpm run build:wasm && pnpm run clean:cache && cd docs && pnpm run dev",
    "dev:docs": "cd docs && pnpm run dev",
    "build": "pnpm run build:wasm && cd docs && pnpm run build",
    "preview": "cd docs && pnpm run preview",
    "rebuild": "pnpm run build:wasm && pnpm run clean:cache",
    "rebuild:clean": "pnpm run build:wasm:clean && pnpm run clean:cache",
    "generate-fixtures": "node scripts/generate-fixtures.mjs",
    "generate-fixtures:force": "node scripts/generate-fixtures.mjs --force",
    "generate-fixtures:verbose": "node scripts/generate-fixtures.mjs --verbose",
    "test-results": "cargo run --release --bin test_reporter -- --output docs/static/test-results.json",
    "compatibility-report": "RUST_TEST_THREADS=1 cargo test --release --test compatibility_report generate_compatibility_report -- --nocapture",
    "list-categories": "cargo test --release --test compatibility_report list_test_categories -- --nocapture",
    "update-docs": "node scripts/update-docs.mjs",
    "test-and-update": "npm run compatibility-report && npm run update-docs",
    "generate-entities": "node scripts/generate-entities-from-svelte.mjs",
    "verify-entities": "node scripts/verify-entities-compatibility.mjs",
    "test": "RUST_TEST_THREADS=2 RAYON_NUM_THREADS=2 cargo test",
    "test:single": "RUST_TEST_THREADS=1 RAYON_NUM_THREADS=1 cargo test",
    "test:release": "RUST_TEST_THREADS=2 RAYON_NUM_THREADS=2 cargo test --release"
  },
  "devDependencies": {
    "oxfmt": "^0.23.0"
  }
}
