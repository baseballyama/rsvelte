# Generated by Cargo
debug
target

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds
*.pdb

# Mutation testing
**/mutants.out*/

# Added by cargo
/target

# WASM build output
/pkg
# Formatter WASM build output (rsvelte_fmt_wasm → browser fmt tool)
/pkg-fmt

# Language server: vendored lint wasm (built via build:wasm:lint-node) + bundle
/apps/npm/language-server/vendor
/apps/npm/language-server/dist
# VS Code extension bundle + packaged vsix
/apps/npm/vscode/dist
/apps/npm/vscode/*.vsix

# svelte-check platform binaries (staged into per-platform npm packages by the
# release workflow; never committed)
/apps/npm/svelte-check-*/svelte-check
/apps/npm/svelte-check-*/svelte-check.exe

# vite-plugin-svelte-native platform .node files (same story — built per
# target in CI, staged into the matching platform package, never committed)
/apps/npm/vite-plugin-svelte-native-*/rsvelte.node

# Stray top-level npm/ dir. Published packages live under apps/npm/ — a
# top-level npm/ only ever appears when a napi build dumps its host-platform
# .node there (the napi-rs default `npmDir`). Never a real source dir here.
/npm/

# rsvelte-fmt platform binaries (staged into per-platform npm packages by the
# release workflow; never committed)
/apps/npm/fmt-*/rsvelte-fmt
/apps/npm/fmt-*/rsvelte-fmt.exe
# rsvelte-fmt native-direct install artifacts (written by `install.js` at
# install time into the consumer's tree; never committed — but guard against a
# local dev run of the postinstall clobbering the JS launcher / leaving a sidecar)
/apps/npm/fmt/bin/rsvelte-fmt.runtime.json

# rsvelte-lint platform binaries + NAPI addon (staged into per-platform npm
# packages by the release workflow / build:lint-native; never committed)
/apps/npm/lint-*/rsvelte-lint
/apps/npm/lint-*/rsvelte-lint.exe
/apps/npm/lint-*/rsvelte_lint.node

# Playwright MCP
.playwright-mcp/

# Docs site
apps/playground/node_modules/
apps/playground/.svelte-kit/
apps/playground/build/

# Generated fixtures (run `npm run generate-fixtures` to regenerate).
# Root-anchored so it ignores the generated top-level `fixtures/` dir but NOT
# source under `scripts/fixtures/` (generators, canonical configs).
/fixtures/

# Test binaries
test_css_debug
test_export_default

# Profiling artifacts
flamegraph.svg
*.flamegraph.svg
perf.data
perf.data.old
*.profraw
*.profdata
samply.json.gz
target/criterion/

# pnpm store
.pnpm-store/

# Node modules
node_modules/

# Claude worktrees
.claude/worktrees/
language-tools

# verify-svelte-compat: per-target ephemeral data. The whole directory
# is regenerated on demand (each target is a clone of an external repo
# the skill bisects against), so nothing inside it should be tracked.
compatibility/verify-svelte-compat/

# Tool / review scratch artefacts. None of these are inputs to a build;
# they're outputs of local tooling (benchmarks, profilers, code-review
# skills) that get regenerated on demand and should not pollute git.
.benchmark-files.txt
benchmark-results.json
.perf-log.md
.perf/
libmagic_string.rlib
profile.json.gz
*.profile.json.gz
REVIEW_REPORT.md
.review-artifacts/
# `pbcopy` here is the user's clipboard-redirect mishap (a markdown
# doc accidentally piped to `> pbcopy`), not the macOS binary. Ignore
# so it doesn't show up in `git status` for everyone who has the same
# pattern in their shell history.
pbcopy

# CI matrix-build artifacts staged into `artifacts/` by the release
# workflow before `stage-*-binaries.mjs` copies them into the per-triple
# npm package dirs. They are downloaded fresh on every run; without this
# entry, `changesets/action` includes them in the "Version Packages" PR
# (~70 MB per run, baked into git history forever).
artifacts/

# Claude scheduled task lock (runtime artifact)
.claude/scheduled_tasks.lock

# Corpus-compat pipeline (generated; see scripts/compat-corpus/)
.corpus-cache/
compatibility/sources/
compatibility/expected/
compatibility/actual/
compatibility/expected-s2t/
compatibility/actual-s2t/
compatibility/manifest.json
compatibility/report.json
compatibility/report-s2t.json

# Lint-compat pipeline (generated; lint-known-failures.json is tracked)
compatibility/lint-sources/
compatibility/lint-manifest.json
compatibility/.lint-rules.json
compatibility/.lint-rsvelte-lint.json
scripts/compat-corpus/lint-oracle/node_modules/
scripts/compat-corpus/lint-oracle/package-lock.json
compatibility/.oxfmt-ignore-nothing
# fmt-parity stage (generated; the fmt-known-failures.json ratchet is checked in)
compatibility/fmt/
compatibility/fmt-report.json

# Dedicated CARGO_TARGET_DIRs used during Phase-3 corpus burndown (never commit)
/target-ast/
/target-rt/
/target-verify/
